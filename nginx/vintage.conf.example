server {
    listen 80;
    server_name example.com;

    root /var/www/vintage/public;
    index index.html;

    client_max_body_size 8m;

    location ^~ /api/ {
        alias /var/www/vintage/backend/;
        index index.php;
        try_files $uri $uri/ =404;
    }

    location ~ ^/api/(.+\.php)$ {
        alias /var/www/vintage/backend/$1;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME /var/www/vintage/backend/$1;
        fastcgi_param SCRIPT_NAME /api/$1;
        fastcgi_pass unix:/run/php/php8.2-fpm.sock;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(?:css|js|mjs|png|jpg|jpeg|gif|svg|ico|webp)$ {
        expires 30d;
        add_header Cache-Control "public, max-age=2592000, immutable";
    }
}